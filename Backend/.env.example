# Copie este arquivo para ".env" (mesma pasta) e preencha com os valores reais.
# O arquivo .env nunca deve ser commitado (já está no .gitignore).

# ── Banco de dados ───────────────────────────────
DB_PASS=

# ── Rota administrativa /usuarios ───────────────
ADMIN_KEY=

# ── Pix (usado para montar o QR Code / "Copia e Cola") ──
# Troque pela chave Pix REAL cadastrada na conta bancária da loja
# para que o QR Code gerado possa receber pagamentos de verdade.
PIX_KEY=pagamentos@nexusimports.com.br
PIX_MERCHANT_NAME=NEXUS IMPORTS
PIX_MERCHANT_CITY=CONTAGEM
